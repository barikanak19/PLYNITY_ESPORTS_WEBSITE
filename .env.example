# Copy to .env in the project root and restart the Vite dev server after changes.
# Production builds also load .env.production (committed with public Cashfree App ID).
# On Vercel, you can override these under Project Settings → Environment Variables.

# Cashfree public App ID (safe for frontend — never put Secret Key here)
VITE_CASHFREE_APP_ID=

# sandbox | production — must match your Cashfree credentials
VITE_CASHFREE_ENV=production

# Server-only Cashfree credentials for Vercel Functions (/api/cashfree/*)
# Set these in Vercel → Project Settings → Environment Variables (no VITE_ prefix)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=production

# Google Sheets webhook URLs (one per tournament sheet)
# Paste each Google Apps Script Web App URL here for its dedicated tournament sheet.
VITE_BGMI_SOLO_FRIDAY=BGMI_SOLO_FRIDAY_URL
VITE_BGMI_DUO_FRIDAY=BGMI_DUO_FRIDAY_URL
VITE_BGMI_SOLO_SATURDAY=BGMI_SOLO_SATURDAY_URL
VITE_BGMI_SQUAD_SATURDAY=BGMI_SQUAD_SATURDAY_URL
VITE_BGMI_SOLO_SUNDAY=BGMI_SOLO_SUNDAY_URL
VITE_BGMI_SQUAD_SUNDAY=BGMI_SQUAD_SUNDAY_URL
VITE_FF_SOLO_FRIDAY=FF_SOLO_FRIDAY_URL
VITE_FF_DUO_FRIDAY=FF_DUO_FRIDAY_URL
VITE_FF_SOLO_SATURDAY=FF_SOLO_SATURDAY_URL
VITE_FF_SQUAD_SATURDAY=FF_SQUAD_SATURDAY_URL
VITE_FF_SOLO_SUNDAY=FF_SOLO_SUNDAY_URL
VITE_FF_SQUAD_SUNDAY=FF_SQUAD_SUNDAY_URL
